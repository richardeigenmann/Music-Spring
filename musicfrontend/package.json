{
  "name": "musicfrontend",
  "version": "0.1.14-SNAPSHOT",
  "scripts": {
    "prestart": "node update-version.js",
    "prebuild": "node update-version.js",
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false --browsers=ChromeHeadless",
    "container:build": "docker build -t musicfrontend .",
    "e2e": "cypress run",
    "cypress:open": "cypress open",
    "lint": "ng lint"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^21.2.6",
    "@angular/common": "^21.2.8",
    "@angular/compiler": "^21.2.8",
    "@angular/core": "^21.2.8",
    "@angular/forms": "^21.2.8",
    "@angular/platform-browser": "^21.2.8",
    "@angular/router": "^21.2.8",
    "angularx-qrcode": "^21.0.5",
    "chart.js": "^4.5.1",
    "express": "^5.2.1",
    "ng2-charts": "^10.0.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.8",
    "@cypress/schematic": "^5.0.0",
    "@eslint/js": "^10.0.1",
    "@types/jasmine": "~5.1.0",
    "angular-eslint": "21.3.1",
    "cypress-recurse": "^1.37.2",
    "eslint": "^10.2.0",
    "jasmine-core": "~5.9.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.58.1"
  }
}
